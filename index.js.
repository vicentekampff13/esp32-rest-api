import express from "express";
import cors from "cors";

const app = express();
app.use(cors());
app.use(express.json({ limit: "200kb" }));

const API_TOKEN = process.env.API_TOKEN || "CAMBIA_ESTO";

function auth(req, res, next) {
  const h = req.headers.authorization || "";
  const token = h.startsWith("Bearer ") ? h.slice(7) : "";
  if (token !== API_TOKEN) return res.status(401).json({ error: "Unauthorized" });
  next();
}

let lastTelemetry = { online: false, ts: 0, data: {} };
let pendingCommand = null;

app.get("/health", (req, res) => res.json({ ok: true, ts: Date.now() }));

app.post("/telemetry", auth, (req, res) => {
  lastTelemetry = { online: true, ts: Date.now(), data: req.body ?? {} };
  res.json({ ok: true });
});

app.get("/state", auth, (req, res) => {
  res.json(lastTelemetry);
});

app.post("/command", auth, (req, res) => {
  const cmd = req.body;
  if (!cmd || typeof cmd !== "object") return res.status(400).json({ error: "Invalid JSON" });

  pendingCommand = { ts: Date.now(), cmd };
  res.json({ ok: true, queued: pendingCommand });
});

app.get("/command", auth, (req, res) => {
  if (!pendingCommand) return res.json({ ok: true, cmd: null });
  const cmd = pendingCommand;
  pendingCommand = null;
  res.json({ ok: true, ...cmd });
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => console.log("API up on port", PORT));